@phdthesis{Chisi2023,
   abstract = {The global trend to provide inclusive education in mainstream public schools means that teachers expected to have knowledge and expertise in areas of learning difficulties like dyslexia, dyspraxia and dyscalculia as they undoubtedly have to teach, at some stage of
their careers, learners who fall into these categories. This study therefore, aimed at exploring teachers’ knowledge of dyslexia. The study composed of 14 teachers, both men and women who taught standard 1 to 5. The study was conducted in Zomba at Mponda
primary school. The study used qualitative approach and in-depth interviews were employed in order to have diverse opinions and experiences. Thematic analysis was used a data analysis method. The study observed that teachers lacked understanding of what
dyslexia is and had misconceptions about its causes and symptoms. It is with this background that the study concludes that teachers lack knowledge of dyslexia. This is due to lack of specialized courses in dyslexia at the teacher training colleges.},
   author = {P. Chisi},
   city = {Lilongwe},
   month = {7},
   title = {EXPLORING KNOWLEDGE OF DYSLEXIA AMONGST
PRIMARY SCHOOL TEACHERS IN ZOMBA DISTRICT: A CASE OF MPONDA PRIMARY SCHOOL.},
   url = {https://minio.seriousbenentertainment.org:9000/phelire/PHELIRE%20CHISI%20DISSERTATION.pdf},
   year = {2023}
}
